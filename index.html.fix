                </tr>
              </thead>
              <tbody id="p1_table_body"></tbody>
              <tfoot>
                <tr class="doc-total-row">
                  <td colspan="3" style="text-align: right; font-weight: 700;">TOTAL</td>
                  <td class="col-nominal" id="p1_total"></td>
                </tr>
              </tfoot>
            </table>
            <div id="p1_notes_manual_wrapper" style="display:none;">
              <div class="doc-notes" style="margin-top: 20px;">
                <div class="doc-notes-title">CATATAN:</div>
                <div class="doc-notes-manual" id="p1_notes_manual"></div>
              </div>
            </div>
            <div class="doc-signatures-p1">
              <div class="doc-sig-box">
                <div class="doc-sig-label">Dibuat Oleh</div>
                <div class="doc-sig-space"></div>
                <div class="doc-sig-name" id="p1_dibuat"></div>
              </div>
              <div class="doc-sig-box">
                <div class="doc-sig-label">Disetujui</div>
                <div class="doc-sig-space"></div>
                <div class="doc-sig-name" id="p1_disetujui"></div>
              </div>
            </div>
            <div class="doc-notes">
              <div class="doc-notes-title">NOTE:</div>
              <div class="doc-notes-content">Dokumen ini adalah bukti pengajuan resmi PT. Nusantara Mineral Sukses Abadi. Harap simpan sebagai arsip.</div>
            </div>
          </div>

          <!-- HALAMAN 2 -->
          <div class="document-page">
            <div class="doc-header-flex">
              <div class="doc-header-left">
                <div class="doc-company-name">PT. NUSANTARA MINERAL SUKSES ABADI</div>
              </div>
              <div class="doc-header-right">
                <div class="doc-form-title-right">BUKTI PENGELUARAN KAS / BANK</div>
                <div class="doc-tanggal-box">Tanggal: <span id="p2_tanggal"></span></div>
              </div>

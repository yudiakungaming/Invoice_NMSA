<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>FinanceSync - Pengajuan HO & Keuangan</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&family=Playfair+Display:wght@600;700&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg: #0c1222;
      --bg-secondary: #141d2f;
      --fg: #f1f5f9;
      --muted: #64748b;
      --accent: #3b82f6;
      --accent-glow: rgba(59, 130, 246, 0.25);
      --card: #1a2642;
      --border: #2a3a5c;
      --success: #10b981;
      --warning: #f59e0b;
      --error: #ef4444;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: 'Space Grotesk', sans-serif;
      background: var(--bg);
      color: var(--fg);
      min-height: 100vh;
      overflow-x: hidden;
    }

    .mono { font-family: 'JetBrains Mono', monospace; }

    .bg-pattern {
      position: fixed;
      inset: 0;
      background-image: radial-gradient(rgba(59, 130, 246, 0.08) 1px, transparent 1px);
      background-size: 32px 32px;
      pointer-events: none;
      z-index: 0;
    }

    .bg-gradient {
      position: fixed;
      inset: 0;
      background: 
        radial-gradient(ellipse 80% 50% at 50% -20%, rgba(59, 130, 246, 0.15), transparent),
        radial-gradient(ellipse 60% 40% at 100% 100%, rgba(16, 185, 129, 0.1), transparent);
      pointer-events: none;
      z-index: 0;
    }

    @keyframes slideUp {
      from { opacity: 0; transform: translateY(30px); }
      to { opacity: 1; transform: translateY(0); }
    }

    @keyframes pulse-ring {
      0% { transform: scale(0.8); opacity: 1; }
      100% { transform: scale(1.5); opacity: 0; }
    }

    .animate-in {
      animation: slideUp 0.7s cubic-bezier(0.16, 1, 0.3, 1) forwards;
      opacity: 0;
    }

    .delay-1 { animation-delay: 0.1s; }
    .delay-2 { animation-delay: 0.2s; }
    .delay-3 { animation-delay: 0.3s; }
    .delay-4 { animation-delay: 0.4s; }

    @media (prefers-reduced-motion: reduce) {
      .animate-in { animation: none; opacity: 1; }
    }

    .input-field {
      background: var(--bg-secondary);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 12px 16px;
      color: var(--fg);
      font-size: 14px;
      width: 100%;
      transition: all 0.2s ease;
      font-family: 'Space Grotesk', sans-serif;
    }

    .input-field:focus {
      outline: none;
      border-color: var(--accent);
      box-shadow: 0 0 0 3px var(--accent-glow);
    }

    .input-field::placeholder { color: var(--muted); }
    .input-field:disabled { opacity: 0.6; cursor: not-allowed; }

    .btn-submit {
      background: linear-gradient(135deg, var(--accent), #2563eb);
      color: white;
      font-weight: 600;
      padding: 14px 28px;
      border-radius: 10px;
      border: none;
      cursor: pointer;
      font-size: 14px;
      font-family: 'Space Grotesk', sans-serif;
      transition: all 0.25s ease;
      display: inline-flex;
      align-items: center;
      gap: 8px;
    }

    .btn-submit:hover:not(:disabled) {
      transform: translateY(-2px);
      box-shadow: 0 8px 25px rgba(59, 130, 246, 0.35);
    }

    .btn-submit:disabled { opacity: 0.7; cursor: not-allowed; }

    .btn-secondary {
      background: transparent;
      border: 1px solid var(--border);
      color: var(--muted);
      padding: 12px 20px;
      border-radius: 10px;
      cursor: pointer;
      font-size: 13px;
      font-family: 'Space Grotesk', sans-serif;
      transition: all 0.2s ease;
    }

    .btn-secondary:hover {
      border-color: var(--accent);
      color: var(--fg);
    }

    .btn-print {
      background: #334155;
      color: white;
      font-weight: 600;
      padding: 14px 28px;
      border-radius: 10px;
      border: none;
      cursor: pointer;
      font-size: 14px;
      font-family: 'Space Grotesk', sans-serif;
      transition: all 0.25s ease;
      display: inline-flex;
      align-items: center;
      gap: 8px;
    }
    .btn-print:hover { background: #475569; transform: translateY(-2px); box-shadow: 0 8px 25px rgba(51,65,85,0.35); }

    .btn-add-item {
      background: rgba(59, 130, 246, 0.15);
      color: var(--accent);
      border: 1px dashed var(--accent);
      width: 100%;
      padding: 10px;
      border-radius: 8px;
      cursor: pointer;
      font-size: 13px;
      transition: 0.2s;
    }
    .btn-add-item:hover { background: rgba(59, 130, 246, 0.25); }

    .btn-remove-item {
      color: var(--error);
      background: rgba(239, 68, 68, 0.1);
      border: none;
      width: 32px;
      height: 38px;
      display: flex;
      align-items: center;
      justify-content: center;
      border-radius: 8px;
      cursor: pointer;
      margin-top: 24px;
    }
    .btn-remove-item:hover { background: rgba(239, 68, 68, 0.2); }

    .card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 24px;
    }

    .status-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      position: relative;
      flex-shrink: 0;
    }

    .status-dot.success { background: var(--success); }
    .status-dot.success::after {
      content: '';
      position: absolute;
      inset: -4px;
      border-radius: 50%;
      border: 2px solid var(--success);
      animation: pulse-ring 2s ease-out infinite;
    }
    .status-dot.pending { background: var(--warning); }
    .status-dot.error { background: var(--error); }

    .history-item {
      background: var(--bg-secondary);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 14px;
      transition: all 0.2s ease;
    }

    .history-item:hover {
      border-color: var(--accent);
      transform: translateX(4px);
    }

    .modal-overlay {
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, 0.85);
      backdrop-filter: blur(8px);
      z-index: 100;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 20px;
      opacity: 0;
      visibility: hidden;
      transition: all 0.3s ease;
    }

    .modal-overlay.show { opacity: 1; visibility: visible; }

    .modal-content {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 20px;
      padding: 28px;
      max-width: 640px;
      width: 100%;
      max-height: 90vh;
      overflow-y: auto;
      transform: scale(0.95);
      transition: transform 0.3s ease;
    }

    .modal-overlay.show .modal-content { transform: scale(1); }

    .modal-document {
      max-width: 100%;
      width: 100%;
      max-height: 95vh;
      background: #e2e8f0;
      padding: 0;
      overflow: hidden;
      border-radius: 16px;
      display: flex;
      flex-direction: column;
    }

    .code-block {
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 16px;
      font-size: 12px;
      line-height: 1.6;
      overflow-x: auto;
    }

    .toast {
      position: fixed;
      bottom: 24px;
      right: 24px;
      padding: 14px 20px;
      border-radius: 10px;
      font-weight: 500;
      font-size: 14px;
      z-index: 200;
      transform: translateY(80px);
      opacity: 0;
      transition: all 0.35s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .toast.show { transform: translateY(0); opacity: 1; }
    .toast.success { background: var(--success); color: white; }
    .toast.error { background: var(--error); color: white; }

    .spinner {
      width: 18px;
      height: 18px;
      border: 2px solid rgba(255,255,255,0.3);
      border-top-color: white;
      border-radius: 50%;
      animation: spin 0.7s linear infinite;
    }

    @keyframes spin { to { transform: rotate(360deg); } }

    .field-label {
      display: block;
      font-size: 13px;
      font-weight: 500;
      color: var(--muted);
      margin-bottom: 6px;
    }

    .currency-wrapper { position: relative; }
    .currency-wrapper .prefix {
      position: absolute;
      left: 14px;
      top: 50%;
      transform: translateY(-50%);
      color: var(--muted);
      font-size: 14px;
    }
    .currency-wrapper input { padding-left: 36px; }

    .tab-btn {
      padding: 8px 16px;
      border-radius: 8px;
      font-size: 13px;
      font-weight: 500;
      color: var(--muted);
      background: transparent;
      border: none;
      cursor: pointer;
      transition: all 0.2s ease;
    }
    .tab-btn:hover { color: var(--fg); background: rgba(255,255,255,0.05); }
    .tab-btn.active { color: var(--accent); background: var(--accent-glow); }

    /* ========== DOCUMENT STYLES ========== */
    
    .documents-container {
      background: #e2e8f0;
      flex: 1;
      overflow-y: auto;
      padding: 40px 20px;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 40px;
    }

    .pdf-wrapper {
      background: white;
      width: 210mm;
    }

    .document-page {
      background: white;
      color: #1e293b;
      padding: 35px 50px;
      font-family: 'Space Grotesk', sans-serif;
      width: 100%;
      min-height: 297mm;
      box-sizing: border-box;
      position: relative;
      overflow: hidden;
      page-break-after: always;
      break-after: page;
    }

    .document-page:last-child {
      page-break-after: auto;
      break-after: auto;
    }

    .page-toolbar {
      position: sticky;
      top: 0;
      z-index: 50;
      width: 100%;
      max-width: 900px;
      display: flex;
      justify-content: flex-end;
      gap: 10px;
      margin-bottom: 20px;
      padding: 12px 20px;
      background: rgba(255,255,255,0.9);
      backdrop-filter: blur(5px);
      border-radius: 12px;
      border: 1px solid #cbd5e1;
      box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
    }

    .btn-print-doc {
      background: #334155;
      color: white;
      font-weight: 600;
      padding: 10px 24px;
      border-radius: 8px;
      border: none;
      cursor: pointer;
      font-size: 13px;
      font-family: 'Space Grotesk', sans-serif;
      transition: all 0.2s ease;
      display: inline-flex;
      align-items: center;
      gap: 8px;
    }
    .btn-print-doc:hover { background: #475569; }

    .doc-header-center {
      text-align: center;
      border-bottom: 2px solid #1e40af;
      padding-bottom: 12px;
      margin-bottom: 20px;
    }

    .doc-company-name {
      font-family: 'Playfair Display', serif;
      font-size: 22px;
      font-weight: 700;
      color: #1e40af;
      letter-spacing: 1px;
      line-height: 1.2;
    }

    .doc-form-title {
      font-size: 14px;
      font-weight: 600;
      margin-top: 5px;
      text-transform: uppercase;
      letter-spacing: 2px;
    }

    .doc-info-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 8px 30px;
      margin-bottom: 20px;
    }

    .doc-info-item { display: flex; gap: 8px; font-size: 13px; }
    .doc-info-label { font-weight: 600; min-width: 80px; color: #334155; }
    .doc-info-value { border-bottom: 1px dashed #94a3b8; flex: 1; padding-bottom: 1px; min-height: 18px; }

    .doc-table { width: 100%; border-collapse: collapse; margin-bottom: 15px; font-size: 12px; }
    .doc-table th {
      background: #1e40af;
      color: white;
      padding: 6px 8px;
      text-align: center;
      font-weight: 600;
      font-size: 11px;
      border: 1px solid #1e40af;
    }
    .doc-table td { border: 1px solid #cbd5e1; padding: 6px 8px; vertical-align: top; }
    .doc-table .col-no { width: 40px; text-align: center; }
    .doc-table .col-item { min-width: 180px; }
    .doc-table .col-qty { width: 70px; text-align: center; }
    .doc-table .col-nominal { width: 120px; text-align: right; }
    .doc-total-row td { background: #f1f5f9; font-weight: 700; font-size: 13px; }

    .doc-signatures-p1 {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 80px;
      margin-top: 20px;
      text-align: center;
      page-break-inside: avoid;
    }

    .doc-sig-box {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: flex-end;
      height: 130px;
    }

    .doc-sig-label { font-size: 11px; font-weight: 600; text-transform: uppercase; color: #334155; margin-bottom: 5px; }
    .doc-sig-space { flex-grow: 1; width: 100%; }
    .doc-sig-name {
      width: 80%;
      font-weight: 700;
      font-size: 12px;
      color: #0f172a;
      padding-bottom: 3px;
      border-bottom: 1px solid #1e293b;
    }

    .doc-header-flex {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      border-bottom: 2px solid #1e40af;
      padding-bottom: 12px;
      margin-bottom: 20px;
    }

    .doc-header-left .doc-company-name { text-align: left; font-size: 20px; }
    .doc-form-title-right { font-size: 13px; font-weight: 600; text-transform: uppercase; letter-spacing: 2px; margin-bottom: 5px; }
    .doc-tanggal-box { font-size: 12px; }
    .doc-tanggal-box span { border-bottom: 1px solid #1e293b; padding: 0 8px; }

    .doc-payment-info { margin-bottom: 15px; font-size: 13px; }
    .doc-payment-row { display: flex; gap: 10px; margin-bottom: 6px; }
    .doc-payment-label { min-width: 140px; font-weight: 600; }
    .doc-payment-value { border-bottom: 1px dashed #94a3b8; flex: 1; padding-bottom: 1px; }

    .doc-notes { margin-top: 20px; padding: 10px 12px; border: 1px solid #cbd5e1; background: #f8fafc; }
    .doc-notes-title { font-weight: 700; font-size: 12px; margin-bottom: 4px; }
    .doc-notes-content { font-size: 11px; color: #64748b; line-height: 1.4; }
    .doc-notes-manual { margin-top: 8px; font-size: 11px; color: #334155; line-height: 1.4; white-space: pre-wrap; }

    .doc-signatures-2x2 { margin-top: 30px; page-break-inside: avoid; }
    .doc-sig-row { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; }
    .doc-sig-row + .doc-sig-row { margin-top: 25px; }

    .sig-block-page2 { display: flex; flex-direction: column; align-items: center; text-align: center; }
    .sig-action { font-size: 10px; text-transform: uppercase; font-weight: 600; letter-spacing: 1px; color: #475569; margin-bottom: 8px; }
    .sig-space { min-height: 50px; width: 100%; }
    .sig-name { font-weight: 700; font-size: 12px; color: #0f172a; margin-bottom: 2px; }
    .sig-title { font-size: 11px; color: #64748b; font-weight: 400; }

    /* ========== @page WAJIB DI LUAR @media print ========== */
    @page {
      size: A4 portrait;
      margin: 0;
    }

    /* ========== PRINT STYLES ========== */
    @media print {
      body { 
        background: white; 
        margin: 0; 
        padding: 0;
        -webkit-print-color-adjust: exact !important;
        print-color-adjust: exact !important;
      }
      
      .no-print, .bg-pattern, .bg-gradient, header, main > div:first-child, .page-toolbar {
        display: none !important;
      }

      #documentModal {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: white;
        z-index: 9999;
        display: block !important;
        opacity: 1 !important;
        visibility: visible !important;
        overflow: visible !important;
      }

      .modal-document {
        max-height: none;
        overflow: visible;
        border-radius: 0;
        display: block;
        background: white;
      }

      .documents-container {
        background: white;
        padding: 0;
        overflow: visible;
        display: block;
        width: 100%;
      }
      
      .pdf-wrapper {
        max-width: none;
        width: 210mm;
        box-shadow: none;
        margin: 0;
      }

      .document-page {
        box-shadow: none;
        margin: 0;
        width: 210mm;
        height: 297mm;
        overflow: hidden;
        page-break-after: always;
        break-after: page;
        padding: 35px 50px; 
      }
      
      .document-page:last-child {
        page-break-after: auto;
        break-after: auto;
      }

      .doc-table th {
        background-color: #1e40af !important;
        -webkit-print-color-adjust: exact !important;
        print-color-adjust: exact !important;
      }
      .doc-total-row td {
        background-color: #f1f5f9 !important;
        -webkit-print-color-adjust: exact !important;
        print-color-adjust: exact !important;
      }
      .doc-notes {
        background-color: #f8fafc !important;
        border-color: #cbd5e1 !important;
        -webkit-print-color-adjust: exact !important;
        print-color-adjust: exact !important;
      }
    }

    ::-webkit-scrollbar { width: 6px; height: 6px; }
    ::-webkit-scrollbar-track { background: var(--bg-secondary); }
    ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }
  </style>
</head>
<body>
  <div class="bg-pattern"></div>
  <div class="bg-gradient"></div>

  <main class="relative z-10 min-h-screen">
    <header class="border-b border-[--border] bg-[--bg]/90 backdrop-blur-lg sticky top-0 z-50 no-print">
      <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
        <div class="flex items-center gap-3 animate-in">
          <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-[--accent] to-cyan-400 flex items-center justify-center">
            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"/>
            </svg>
          </div>
          <div>
            <h1 class="text-lg font-semibold">FinanceSync</h1>
            <p class="text-xs text-[--muted]">PT Nusantara Mineral Sukses Abadi</p>
          </div>
        </div>

        <div class="flex items-center gap-3 animate-in delay-1">
          <div class="flex items-center gap-2 px-3 py-2 rounded-lg bg-[--bg-secondary]">
            <div class="status-dot success"></div>
            <span class="text-sm text-[--muted]">Synced</span>
          </div>
          <button id="setupBtn" class="btn-secondary" aria-label="Pengaturan">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
          </button>
        </div>
      </div>
    </header>

    <div class="max-w-6xl mx-auto px-6 py-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8 no-print">
        <div class="card animate-in delay-1">
          <div class="text-[--muted] text-xs uppercase tracking-wide mb-1">Total Entri</div>
          <div class="text-2xl font-bold" id="totalData">0</div>
        </div>
        <div class="card animate-in delay-2">
          <div class="text-[--muted] text-xs uppercase tracking-wide mb-1">Terkirim</div>
          <div class="text-2xl font-bold text-[--success]" id="sentData">0</div>
        </div>
        <div class="card animate-in delay-3">
          <div class="text-[--muted] text-xs uppercase tracking-wide mb-1">Menunggu</div>
          <div class="text-2xl font-bold text-[--warning]" id="pendingData">0</div>
        </div>
        <div class="card animate-in delay-4">
          <div class="text-[--muted] text-xs uppercase tracking-wide mb-1">Gagal</div>
          <div class="text-2xl font-bold text-[--error]" id="failedData">0</div>
        </div>
      </div>

      <div class="grid lg:grid-cols-5 gap-8">
        <div class="lg:col-span-3 no-print">
          <div class="card animate-in delay-3">
            <div class="flex items-center gap-3 mb-6">
              <div class="w-10 h-10 rounded-xl bg-[--accent-glow] flex items-center justify-center">
                <svg class="w-5 h-5 text-[--accent]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/>
                </svg>
              </div>
              <div>
                <h2 class="text-lg font-semibold">Form Pengajuan</h2>
                <p class="text-sm text-[--muted]">Input data keuangan & dokumen</p>
              </div>
            </div>

            <form id="dataForm" class="space-y-4">
              <div class="grid md:grid-cols-2 gap-4">
                <div>
                  <label class="field-label" for="tanggal">Tanggal Invoice</label>
                  <input type="date" id="tanggal" name="tanggal" class="input-field" required>
                </div>
                <div>
                  <label class="field-label" for="lokasi">Lokasi</label>
                  <input type="text" id="lokasi" name="lokasi" class="input-field" placeholder="Contoh: Lt.1">
                </div>
              </div>

              <div class="grid md:grid-cols-2 gap-4">
                <div>
                  <label class="field-label" for="jenis_pengajuan">Jenis Pengajuan</label>
                  <input type="text" id="jenis_pengajuan" name="jenis_pengajuan" class="input-field" placeholder="Masukkan jenis pengajuan">
                </div>
                <div>
                  <label class="field-label" for="kode">Kode</label>
                  <input type="text" id="kode" name="kode" class="input-field mono" placeholder="Masukkan kode">
                </div>
              </div>

              <div class="grid md:grid-cols-2 gap-4">
                <div>
                  <label class="field-label" for="no_invoice">No Invoice / Berkas</label>
                  <input type="text" id="no_invoice" name="no_invoice" class="input-field mono" placeholder="Nomor invoice">
                </div>
                <div>
                  <label class="field-label" for="status">Status Pembayaran</label>
                  <select id="status" name="status" class="input-field">
                    <option value="">Pilih status</option>
                    <option value="Lunas">Lunas</option>
                    <option value="Belum Lunas">Belum Lunas</option>
                  </select>
                </div>
              </div>

              <div>
                <div class="flex justify-between items-center mb-2">
                  <label class="field-label">Rincian Barang / Jasa</label>
                  <span class="text-xs text-[--muted]">Isi nominal per item</span>
                </div>
                <div id="itemsContainer" class="space-y-2"></div>
                <button type="button" onclick="addFormItem()" class="btn-add-item mt-3">+ Tambah Item Baru</button>
              </div>

              <div class="grid md:grid-cols-2 gap-4">
                <div>
                  <label class="field-label">Total Nominal (Otomatis)</label>
                  <div class="currency-wrapper">
                    <span class="prefix">Rp</span>
                    <input type="text" id="grandTotalDisplay" class="input-field mono" readonly placeholder="0" style="background: rgba(255,255,255,0.05);">
                  </div>
                </div>
                <div id="paymentDateContainer">
                  <label class="field-label" for="tanggal_pembayaran">Tanggal Pembayaran</label>
                  <input type="date" id="tanggal_pembayaran" name="tanggal_pembayaran" class="input-field">
                </div>
              </div>

              <div>
                <label class="field-label" for="dibayarkan_kepada">Dibayarkan Kepada</label>
                <input type="text" id="dibayarkan_kepada" name="dibayarkan_kepada" class="input-field" placeholder="Nama penerima pembayaran">
              </div>

              <div>
                <label class="field-label" for="catatan_tambahan">Catatan Tambahan <span class="text-[--muted] font-normal">(opsional, muncul di dokumen)</span></label>
                <textarea id="catatan_tambahan" name="catatan_tambahan" rows="2" class="input-field resize-none" placeholder="Tambahkan catatan khusus untuk dokumen..."></textarea>
              </div>

              <div class="flex flex-wrap items-center gap-3 pt-4">
                <button type="submit" id="submitBtn" class="btn-submit">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/>
                  </svg>
                  <span>Kirim ke Spreadsheet</span>
                </button>
                <button type="button" id="previewBtn" class="btn-print">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                  </svg>
                  <span>Preview & Print</span>
                </button>
                <button type="reset" class="text-[--muted] hover:text-[--fg] transition-colors text-sm">Reset</button>
              </div>
            </form>
          </div>
        </div>

        <div class="lg:col-span-2 no-print">
          <div class="card animate-in delay-4">
            <div class="flex items-center justify-between mb-4">
              <h2 class="text-lg font-semibold">Riwayat</h2>
              <button id="clearHistory" class="text-xs text-[--muted] hover:text-[--error] transition-colors">Hapus</button>
            </div>

            <div class="flex gap-1 mb-4 p-1 bg-[--bg-secondary] rounded-lg">
              <button class="tab-btn active flex-1" data-tab="all">Semua</button>
              <button class="tab-btn flex-1" data-tab="success">Sukses</button>
              <button class="tab-btn flex-1" data-tab="pending">Pending</button>
            </div>

            <div id="historyList" class="space-y-2 max-h-[500px] overflow-y-auto pr-1">
              <div class="text-center py-10 text-[--muted]">
                <svg class="w-10 h-10 mx-auto mb-3 opacity-40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                </svg>
                <p class="text-sm">Belum ada data</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>

  <!-- Setup Modal -->
  <div id="setupModal" class="modal-overlay" role="dialog" aria-modal="true">
    <div class="modal-content">
      <div class="flex items-center justify-between mb-5">
        <h2 class="text-lg font-semibold">Setup Integrasi</h2>
        <button id="closeModal" class="w-8 h-8 rounded-lg hover:bg-[--bg-secondary] flex items-center justify-center transition-colors" aria-label="Tutup">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
      <div class="space-y-5">
        <div>
          <label class="field-label">URL Webhook (Google Apps Script)</label>
          <input type="url" id="webhookUrl" class="input-field mono text-sm" placeholder="https://script.google.com/macros/s/xxx/exec">
        </div>
        <div class="bg-[--bg-secondary] rounded-xl p-4">
          <h3 class="font-medium text-sm mb-3 flex items-center gap-2">
            <svg class="w-4 h-4 text-[--accent]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            Langkah Setup
          </h3>
          <ol class="text-xs text-[--muted] space-y-1.5 list-decimal list-inside">
            <li>Buka spreadsheet Anda di Google Sheets</li>
            <li>Klik Extensions > Apps Script</li>
            <li>Hapus kode default, paste kode di bawah</li>
            <li>Klik Deploy > New deployment</li>
            <li>Pilih "Web app", set access ke "Anyone"</li>
            <li>Copy URL dan paste di atas, lalu Simpan</li>
          </ol>
        </div>
        <div>
          <div class="flex items-center justify-between mb-2">
            <label class="field-label mb-0">Kode Script</label>
            <button id="copyCode" class="text-xs text-[--accent] hover:underline">Copy</button>
          </div>
          <div class="code-block mono text-[--muted] text-xs">
            <pre id="scriptCode">function doPost(e) {
  try {
    var sheet = SpreadsheetApp.getActiveSpreadsheet().getActiveSheet();
    var data = JSON.parse(e.postData.contents);
    
    if (sheet.getLastRow() === 0) {
      sheet.appendRow([
        'No', 'Tanggal', 'Lokasi', 'Kode', 'Jenis_Pengajuan',
        'No_Invoice', 'Keterangan', 'Quantity', 'Status', 'Nominal', 
        'Tanggal_Bayar', 'Dibayarkan_Kepada', 'Catatan_Tambahan',
        'Dibuat_Oleh', 'Disetujui_Oleh', 'Keuangan', 'Dir_Keuangan', 
        'Direktur_Utama', 'Accounting'
      ]);
    }
    
    var lastRow = sheet.getLastRow();
    var itemDetails = "";
    if(data.items && data.items.length > 0) {
       itemDetails = data.items.map(i => i.ket + " (" + i.qty + ") - " + i.nominal).join("; ");
    }
    
    sheet.appendRow([
      lastRow, data.tanggal, data.lokasi, data.kode,
      data.jenis_pengajuan, data.no_invoice, itemDetails,
      "-", data.status, data.total_nominal,
      data.tanggal_pembayaran, data.dibayarkan_kepada,
      data.catatan_tambahan, data.dibuat_oleh, data.disetujui_oleh,
      data.keuangan, data.dir_keuangan, data.direktur_utama, data.accounting
    ]);
    
    return ContentService.createTextOutput(
      JSON.stringify({ success: true })
    ).setMimeType(ContentService.MimeType.JSON);
    
  } catch (error) {
    return ContentService.createTextOutput(
      JSON.stringify({ success: false, message: error.toString() })
    ).setMimeType(ContentService.MimeType.JSON);
  }
}</pre>
          </div>
        </div>
        <button id="saveConfig" class="btn-submit w-full justify-center">Simpan Konfigurasi</button>
      </div>
    </div>
  </div>

  <!-- Document Preview Modal -->
  <div id="documentModal" class="modal-overlay" role="dialog" aria-modal="true">
    <div class="modal-content modal-document">
      <div class="flex items-center justify-between px-6 py-4 bg-white border-b border-gray-200 no-print page-toolbar">
        <h2 class="text-lg font-semibold text-slate-800">Preview Dokumen</h2>
        <div class="flex items-center gap-2">
          <button class="btn-print-doc" onclick="window.print()">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"/>
            </svg>
            Print Dokumen
          </button>
          <button id="closeDocModal" class="w-8 h-8 rounded-lg hover:bg-slate-100 flex items-center justify-center transition-colors text-slate-600" aria-label="Tutup">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>
        </div>
      </div>

      <div class="documents-container">
        <div id="pdf-wrapper" class="pdf-wrapper">
          
          <!-- HALAMAN 1 -->
          <div class="document-page">
            <div class="doc-header-center">
              <div class="doc-company-name">PT. NUSANTARA MINERAL SUKSES ABADI</div>
              <div class="doc-form-title">FORMULIR PENGAJUAN HO</div>
            </div>
            <div class="doc-info-grid">
              <div class="doc-info-item">
                <span class="doc-info-label">Lokasi</span>
                <span class="doc-info-value" id="p1_lokasi"></span>
              </div>
              <div class="doc-info-item">
                <span class="doc-info-label">Tanggal</span>
                <span class="doc-info-value" id="p1_tanggal"></span>
              </div>
              <div class="doc-info-item">
                <span class="doc-info-label">Kode</span>
                <span class="doc-info-value" id="p1_kode"></span>
              </div>
              <div class="doc-info-item">
                <span class="doc-info-label">Jenis</span>
                <span class="doc-info-value" id="p1_jenis"></span>
              </div>
            </div>
            <table class="doc-table">
              <thead>
                <tr>
                  <th class="col-no">NO</th>
                  <th class="col-item">URAIAN BARANG / JASA</th>

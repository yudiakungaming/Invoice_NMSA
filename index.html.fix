                  <div class="sig-action">Disetujui</div>
                  <div class="sig-space"></div>
                  <div class="sig-name" id="p2_name_dirkeuangan"></div>
                  <div class="sig-title">Dir. Keuangan</div>
                </div>
              </div>
              <div class="doc-sig-row">
                <div class="sig-block-page2">
                  <div class="sig-action">Disetujui</div>
                  <div class="sig-space"></div>
                  <div class="sig-name" id="p2_name_direktur"></div>
                  <div class="sig-title">Direktur Utama</div>
                </div>
                <div class="sig-block-page2">
                  <div class="sig-action">Dibukukan</div>
                  <div class="sig-space"></div>
                  <div class="sig-name" id="p2_name_accounting"></div>
                  <div class="sig-title">Accounting</div>
                </div>
              </div>
            </div>
            <div class="doc-notes">
              <div class="doc-notes-title">NOTE:</div>
              <div class="doc-notes-content">Dokumen ini adalah bukti pengeluaran kas/bank resmi PT. Nusantara Mineral Sukses Abadi. Harap simpan sebagai arsip.</div>

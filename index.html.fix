          </div>
          
        </div>
      </div>
    </div>
  </div>

  <div id="toast" class="toast" role="alert"></div>

  <script>
    const state = {
      webhookUrl: localStorage.getItem('webhookUrl') || '',
      history: JSON.parse(localStorage.getItem('submissionHistory') || '[]'),
      currentTab: 'all',
      lastFormData: null,
      items: [{ ket: '', qty: '', nominal: 0 }]
    };

    let elements = {};

    function init() {
      elements = {
        form: document.getElementById('dataForm'),
        submitBtn: document.getElementById('submitBtn'),
        previewBtn: document.getElementById('previewBtn'),
        historyList: document.getElementById('historyList'),
        setupModal: document.getElementById('setupModal'),
        documentModal: document.getElementById('documentModal'),
        setupBtn: document.getElementById('setupBtn'),
        closeModal: document.getElementById('closeModal'),
        closeDocModal: document.getElementById('closeDocModal'),
        webhookInput: document.getElementById('webhookUrl'),
        saveConfig: document.getElementById('saveConfig'),
        copyCode: document.getElementById('copyCode'),
        clearHistory: document.getElementById('clearHistory'),
        toast: document.getElementById('toast'),
        totalData: document.getElementById('totalData'),
        sentData: document.getElementById('sentData'),
        pendingData: document.getElementById('pendingData'),
        failedData: document.getElementById('failedData'),
        tabBtns: document.querySelectorAll('.tab-btn'),
        grandTotalDisplay: document.getElementById('grandTotalDisplay'),
        statusInput: document.getElementById('status'),
        paymentDateContainer: document.getElementById('paymentDateContainer')
      };

      if (state.webhookUrl) elements.webhookInput.value = state.webhookUrl;
      document.getElementById('tanggal').valueAsDate = new Date();

      renderFormItems();
      renderHistory();
      updateStats();
      setupEventListeners();
    }

    function setupEventListeners() {
      elements.form.addEventListener('submit', handleSubmit);
      elements.previewBtn.addEventListener('click', handlePreview);

      elements.statusInput.addEventListener('change', (e) => {
        elements.paymentDateContainer.style.display = e.target.value === 'Lunas' ? 'block' : 'none';
        if (e.target.value !== 'Lunas') document.getElementById('tanggal_pembayaran').value = '';
      });

      if (elements.statusInput.value !== 'Lunas') elements.paymentDateContainer.style.display = 'none';

      elements.setupBtn.addEventListener('click', () => elements.setupModal.classList.add('show'));
      elements.closeModal.addEventListener('click', () => elements.setupModal.classList.remove('show'));
      elements.setupModal.addEventListener('click', (e) => {
        if (e.target === elements.setupModal) elements.setupModal.classList.remove('show');
      });
      elements.closeDocModal.addEventListener('click', () => elements.documentModal.classList.remove('show'));

      elements.saveConfig.addEventListener('click', () => {
        const url = elements.webhookInput.value.trim();
        if (url) {
          state.webhookUrl = url;
          localStorage.setItem('webhookUrl', url);
          showToast('Konfigurasi tersimpan', 'success');
          elements.setupModal.classList.remove('show');
        } else {
          showToast('Masukkan URL webhook', 'error');
        }
      });

      elements.copyCode.addEventListener('click', () => {
        navigator.clipboard.writeText(document.getElementById('scriptCode').textContent)
          .then(() => showToast('Kode disalin', 'success'));
      });

      elements.clearHistory.addEventListener('click', () => {
        if (confirm('Hapus semua riwayat?')) {
          state.history = [];
          localStorage.removeItem('submissionHistory');
          renderHistory();
          updateStats();
          showToast('Riwayat dihapus', 'success');
        }
      });

      elements.tabBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          elements.tabBtns.forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
          state.currentTab = btn.dataset.tab;
          renderHistory();
        });
      });

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') {
          elements.setupModal.classList.remove('show');
          elements.documentModal.classList.remove('show');
        }
      });
    }

    function renderFormItems() {
      const container = document.getElementById('itemsContainer');
      container.innerHTML = '';
      state.items.forEach((item, index) => {
        const row = document.createElement('div');
        row.className = 'grid grid-cols-12 gap-2 items-start';
        row.innerHTML = `
          <div class="col-span-5">
            <label class="field-label text-[10px]">Uraian</label>
            <input type="text" class="input-field text-sm" placeholder="Nama barang/jasa" value="${escapeHtml(item.ket)}" oninput="updateItem(${index}, 'ket', this.value)">
          </div>
          <div class="col-span-2">
            <label class="field-label text-[10px]">Qty</label>
            <input type="text" class="input-field text-sm text-center" placeholder="1" value="${escapeHtml(item.qty)}" oninput="updateItem(${index}, 'qty', this.value)">
          </div>
          <div class="col-span-4">
            <label class="field-label text-[10px]">Nominal</label>
            <div class="currency-wrapper">
              <span class="prefix" style="font-size:12px">Rp</span>
              <input type="number" class="input-field text-sm mono" placeholder="0" value="${item.nominal || ''}" oninput="updateItem(${index}, 'nominal', this.value)">
            </div>
          </div>
          <div class="col-span-1 flex justify-end">
            ${state.items.length > 1 ? `
            <button type="button" onclick="removeFormItem(${index})" class="btn-remove-item" title="Hapus">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
            </button>` : '<div style="height:38px"></div>'}
          </div>
        `;
        container.appendChild(row);
      });
      calculateTotal();
    }

    window.addFormItem = function() {
      state.items.push({ ket: '', qty: '', nominal: 0 });
      renderFormItems();
    }

    window.removeFormItem = function(index) {
      if (state.items.length <= 1) return;
      state.items.splice(index, 1);
      renderFormItems();
    }

    window.updateItem = function(index, key, value) {
      state.items[index][key] = value;
      if (key === 'nominal') calculateTotal();
    }

    function calculateTotal() {
      const total = state.items.reduce((acc, curr) => acc + (parseInt(curr.nominal) || 0), 0);
      elements.grandTotalDisplay.value = formatNumber(total);
      return total;
    }

    function getFormData() {
      const formData = new FormData(elements.form);
      return {
        tanggal: formData.get('tanggal') || '',
        lokasi: formData.get('lokasi') || '',
        kode: formData.get('kode') || '',
        jenis_pengajuan: formData.get('jenis_pengajuan') || '',
        no_invoice: formData.get('no_invoice') || '',
        status: formData.get('status') || '',
        items: [...state.items],
        total_nominal: calculateTotal(),
        tanggal_pembayaran: formData.get('tanggal_pembayaran') || '',
        dibayarkan_kepada: formData.get('dibayarkan_kepada') || '',
        catatan_tambahan: formData.get('catatan_tambahan') || '',
        dibuat_oleh: 'Nur Wahyudi',
        disetujui_oleh: 'Harijon',
        keuangan: 'Andi Dhiya Salsabila',
        dir_keuangan: 'Harijon',
        direktur_utama: 'H. Andi Nursyam Halid',
        accounting: 'Sri Ekowati'
      };
    }

    function handlePreview() {
      const data = getFormData();
      if (data.items.length === 0 || data.items.every(i => !i.ket)) {
        showToast('Lengkapi minimal 1 item', 'error');
        return;
      }
      state.lastFormData = data;
      populateDocuments(data);
      elements.documentModal.classList.add('show');
    }

    function populateDocuments(data) {
      const formattedTotal = 'Rp ' + formatNumber(data.total_nominal);

      document.getElementById('p1_lokasi').textContent = data.lokasi || '-';
      document.getElementById('p1_tanggal').textContent = formatDate(data.tanggal);
      document.getElementById('p1_kode').textContent = data.kode || '-';
      document.getElementById('p1_jenis').textContent = data.jenis_pengajuan || '-';
      document.getElementById('p1_total').textContent = formattedTotal;
      document.getElementById('p1_dibuat').textContent = data.dibuat_oleh;
      document.getElementById('p1_disetujui').textContent = data.disetujui_oleh;

      document.getElementById('p2_tanggal').textContent = formatDate(data.tanggal);
      document.getElementById('p2_kode').textContent = data.kode || '-';
      document.getElementById('p2_dibayarkan').textContent = data.dibayarkan_kepada || '-';
      document.getElementById('p2_jenis').textContent = data.jenis_pengajuan || '-';
      document.getElementById('p2_total').textContent = formattedTotal;
      document.getElementById('p2_name_keuangan').textContent = data.keuangan;
      document.getElementById('p2_name_dirkeuangan').textContent = data.dir_keuangan;
      document.getElementById('p2_name_direktur').textContent = data.direktur_utama;
      document.getElementById('p2_name_accounting').textContent = data.accounting;

      const tbody1 = document.getElementById('p1_table_body');
      const tbody2 = document.getElementById('p2_table_body');
      tbody1.innerHTML = '';
      tbody2.innerHTML = '';

      data.items.forEach((item, idx) => {
        const row = `
          <tr>
            <td style="text-align: center;">${idx + 1}</td>
            <td>${escapeHtml(item.ket)}</td>
            <td style="text-align: center;">${escapeHtml(item.qty)}</td>
            <td style="text-align: right;">${item.nominal ? 'Rp ' + formatNumber(item.nominal) : '-'}</td>
          </tr>
        `;
        tbody1.innerHTML += row;
        tbody2.innerHTML += row;
      });

      const p1W = document.getElementById('p1_notes_manual_wrapper');
      const p1C = document.getElementById('p1_notes_manual');
      const p2W = document.getElementById('p2_notes_manual_wrapper');
      const p2C = document.getElementById('p2_notes_manual');

      if (data.catatan_tambahan && data.catatan_tambahan.trim()) {
        p1W.style.display = 'block'; p1C.textContent = data.catatan_tambahan.trim();
        p2W.style.display = 'block'; p2C.textContent = data.catatan_tambahan.trim();
      } else {
        p1W.style.display = 'none'; p2W.style.display = 'none';
      }
    }

    async function handleSubmit(e) {
      e.preventDefault();

      if (!state.webhookUrl) {
        showToast('Setup webhook terlebih dahulu', 'error');
        elements.setupModal.classList.add('show');
        return;
      }

      const data = getFormData();
      const historyItem = { id: Date.now(), ...data, status_submit: 'pending', timestamp: new Date().toISOString() };

      state.history.unshift(historyItem);
      state.lastFormData = data;
      saveHistory();
      renderHistory();
      updateStats();

      elements.submitBtn.disabled = true;
      elements.submitBtn.innerHTML = '<div class="spinner"></div><span>Mengirim...</span>';

      try {
        await fetch(state.webhookUrl, {
          method: 'POST',
          mode: 'no-cors',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data)
        });

        const idx = state.history.findIndex(h => h.id === historyItem.id);
        if (idx !== -1) { state.history[idx].status_submit = 'success'; saveHistory(); renderHistory(); updateStats(); }

        showToast('Data berhasil dikirim', 'success');
        populateDocuments(data);
        elements.documentModal.classList.add('show');

      } catch (error) {
        const idx = state.history.findIndex(h => h.id === historyItem.id);
        if (idx !== -1) { state.history[idx].status_submit = 'error'; saveHistory(); renderHistory(); updateStats(); }
        showToast('Gagal: ' + error.message, 'error');
      }

      elements.submitBtn.disabled = false;
      elements.submitBtn.innerHTML = `
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/>
        </svg>
        <span>Kirim ke Spreadsheet</span>
      `;
    }

    function renderHistory() {
      let filtered = state.currentTab === 'all' ? state.history : state.history.filter(h => h.status_submit === state.currentTab);

      if (filtered.length === 0) {
        elements.historyList.innerHTML = `
          <div class="text-center py-10 text-[--muted]">
            <svg class="w-10 h-10 mx-auto mb-3 opacity-40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
            </svg>
            <p class="text-sm">Belum ada data</p>
          </div>`;
        return;
      }

      elements.historyList.innerHTML = filtered.slice(0, 30).map(item => `
        <div class="history-item cursor-pointer" onclick="loadHistoryItem(${item.id})">
          <div class="flex items-start justify-between gap-3">
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2">
                <span class="font-medium text-sm mono">${escapeHtml(item.no_invoice || '-')}</span>
                <span class="status-dot ${item.status_submit}"></span>
              </div>
              <div class="text-xs text-[--muted] truncate mt-0.5">${item.items.length} Item(s)</div>
              <div class="flex items-center gap-3 mt-1.5">
                <span class="text-xs font-medium text-[--accent]">Rp ${formatNumber(item.total_nominal)}</span>
                <span class="text-xs text-[--muted]">${escapeHtml(item.jenis_pengajuan || '-')}</span>
              </div>
            </div>
            <div class="text-xs text-[--muted] text-right whitespace-nowrap">${formatTime(item.timestamp)}</div>
          </div>
        </div>`).join('');
    }

    window.loadHistoryItem = function(id) {
      const item = state.history.find(h => h.id === id);
      if (item) {
        state.items = item.items;
        renderFormItems();
        populateDocuments(item);
        elements.documentModal.classList.add('show');
      }
    };

    function updateStats() {
      animateCounter(elements.totalData, state.history.length);
      animateCounter(elements.sentData, state.history.filter(h => h.status_submit === 'success').length);
      animateCounter(elements.pendingData, state.history.filter(h => h.status_submit === 'pending').length);
      animateCounter(elements.failedData, state.history.filter(h => h.status_submit === 'error').length);
    }

    function animateCounter(el, target) {
      const current = parseInt(el.textContent) || 0;
      if (current === target) return;
      const start = performance.now();
      const duration = 400;
      function update(t) {
        const p = Math.min((t - start) / duration, 1);
        el.textContent = Math.round(current + (target - current) * (1 - Math.pow(1 - p, 3)));
        if (p < 1) requestAnimationFrame(update);
      }
      requestAnimationFrame(update);
    }

    function saveHistory() { localStorage.setItem('submissionHistory', JSON.stringify(state.history)); }

    function showToast(message, type) {
      elements.toast.textContent = message;
      elements.toast.className = `toast ${type} show`;
      setTimeout(() => elements.toast.classList.remove('show'), 3000);
    }

    function formatDate(dateStr) {
      if (!dateStr) return '-';
      return new Date(dateStr + 'T00:00:00').toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' });
    }

    function formatTime(iso) {
      return new Date(iso).toLocaleString('id-ID', { day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit' });
    }

    function formatNumber(num) { return (num || 0).toString().replace(/\B(?=(\d{3})+(?!\d))/g, '.'); }

    function escapeHtml(text) { const d = document.createElement('div'); d.textContent = text || ''; return d.innerHTML; }

    document.addEventListener('DOMContentLoaded', init);
  </script>
</body>
</html>

function syncFromFirebase() {

  const FIREBASE_PROJECT_ID = "ai-devender-7b55c";
  const url = `https://firestore.googleapis.com/v1/projects/${FIREBASE_PROJECT_ID}/databases/(default)/documents/submissions?pageSize=1000&orderBy=timestamp`;

  const response = UrlFetchApp.fetch(url);
  const result = JSON.parse(response.getContentText());

  const sheet = SpreadsheetApp.getActiveSpreadsheet().getActiveSheet();
  sheet.clearContents();

  // Header
  sheet.appendRow([
    "No",
    "Tanggal",
    "Lokasi",
    "Kode",
    "No Invoice",
    "Jenis Pengajuan",        // ← Kolom ini akan terisi sekarang!
    "Nominal (Rp)",
    "Status",
    "Dibayarkan Kepada",
    "Catatan"
  ]);

  if (!result.documents) return;

  result.documents.forEach((doc, index) => {

    const f = doc.fields || {};

    sheet.appendRow([
      index + 1,
      f.tanggal?.stringValue || "",
      f.lokasi?.stringValue || "",
      f.kode?.stringValue || "",
      f.no_invoice?.stringValue || "",
      f.jenis_pengajuan?.stringValue || "",       // ✅ SUDAH DIPERBAIKI (dari jenis_pengajuan_summary)
      f.total_nominal?.integerValue || "",
      f.status?.stringValue || "",
      f.dibayarkan_kepada?.stringValue || "",
      f.catatan_tambahan?.stringValue || ""
    ]);

  });

  // Format nominal ke Rupiah
  const lastRow = sheet.getLastRow();
  if (lastRow > 1) {
    sheet.getRange(2, 7, lastRow - 1).setNumberFormat('"Rp" #,##0');
  }

}
